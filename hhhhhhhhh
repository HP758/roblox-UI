local function ripple(parent, x, y, color, size)
	local r = Instance.new("Frame")
	r.AnchorPoint = Vector2.new(0.5, 0.5)
	r.Position = UDim2.fromOffset(x, y)
	r.Size = UDim2.fromOffset(0, 0)
	r.BackgroundColor3 = color or Color3.fromRGB(255,255,255)
	r.BackgroundTransparency = 0.5
	r.BorderSizePixel = 0
	r.ZIndex = (parent.ZIndex or 0) + 1
	r.Parent = parent
	corner(r, UDim.new(1,0))
	tw(r, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {
		Size = UDim2.fromOffset(size or 200, size or 200),
		BackgroundTransparency = 1,
	})
	task.delay(0.55, function() if r.Parent then r:Destroy() end end)
end

local function spawnParticles(parent, x, y, color, count)
	count = count or 8
	for i = 1, count do
		local p = Instance.new("Frame")
		p.AnchorPoint = Vector2.new(0.5, 0.5)
		p.Position = UDim2.fromOffset(x, y)
		p.Size = UDim2.fromOffset(4, 4)
		p.BackgroundColor3 = color or Color3.fromRGB(255,255,255)
		p.BorderSizePixel = 0
		p.ZIndex = (parent.ZIndex or 0) + 2
		p.Parent = parent
		corner(p, UDim.new(1,0))

		local ang = (math.pi * 2 / count) * i + math.random()*0.3
		local dist = math.random(40, 80)
		local dx = math.cos(ang) * dist
		local dy = math.sin(ang) * dist

		tw(p, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
			Position = UDim2.fromOffset(x + dx, y + dy),
			Size = UDim2.fromOffset(0, 0),
			BackgroundTransparency = 1,
		})
		task.delay(0.65, function() if p.Parent then p:Destroy() end end)
	end
end

