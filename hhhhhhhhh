			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextColor3 = T.Text
			l.Text = text
			l.ZIndex = 16
			l.Parent = r

			local tlbl = Instance.new("TextLabel")
			tlbl.BackgroundTransparency = 1
			tlbl.AnchorPoint = Vector2.new(1, 0.5)
			tlbl.Position = UDim2.new(1, -12, 0.5, 0)
			tlbl.Size = UDim2.fromOffset(80, 24)
			tlbl.Font = Enum.Font.GothamBold
			tlbl.TextSize = 14
			tlbl.TextXAlignment = Enum.TextXAlignment.Right
			tlbl.TextColor3 = T.Accent
			tlbl.Text = "00:00"
			tlbl.ZIndex = 16
			tlbl.Parent = r

			local running = false
			local remaining = seconds or 60

			local function format(s)
				local m = math.floor(s/60)
				local sec = s % 60
				return string.format("%02d:%02d", m, sec)
			end

			tlbl.Text = format(remaining)

			local api = {Instance = r}
			function api:Start()
				if running then return end
				running = true
				task.spawn(function()
					while running and remaining > 0 do
						task.wait(1)
						if not running then return end
						remaining = remaining - 1
						tlbl.Text = format(remaining)
						if remaining == 0 then
							running = false
							if onComplete then task.spawn(onComplete) end
						end
					end
				end)
			end
			function api:Stop() running = false end
			function api:Reset(s) remaining = s or seconds; tlbl.Text = format(remaining) end
			return api
		end

