			fill.BackgroundColor3 = T.Accent
			fill.BorderSizePixel = 0
			fill.ZIndex = 17
			fill.Parent = track
			corner(fill, UDim.new(1,0))
			-- 彩虹填充色
			local fillGrad = Instance.new("UIGradient")
			fillGrad.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, T.Rainbow2),
				ColorSequenceKeypoint.new(1, T.Rainbow3),
			})
			fillGrad.Parent = fill

			local thumb = Instance.new("Frame")
			thumb.AnchorPoint = Vector2.new(0.5, 0.5)
			thumb.Position = UDim2.new((default-min)/math.max(max-min,1), 0, 0.5, 0)
			thumb.Size = UDim2.fromOffset(14, 14)
			thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
			thumb.BorderSizePixel = 0
			thumb.ZIndex = 18
			thumb.Parent = track
			corner(thumb, UDim.new(1,0))
			stroke(thumb, T.Accent, 0, 2)

			local hit = Instance.new("TextButton")
			hit.BackgroundTransparency = 1
			hit.Text = ""
			hit.Size = UDim2.new(1, 20, 0, 30)
			hit.Position = UDim2.new(0, -10, 0.5, -15)
			hit.ZIndex = 19
			hit.AutoButtonColor = false
			hit.Active = true
			hit.Parent = track

			local dragging = false
			local lastValue = default
			local function setFromX(x)
				local rel = math.clamp((x - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
				local v = math.floor(min + (max - min) * rel + 0.5)
				fill.Size = UDim2.new(rel, 0, 1, 0)
				thumb.Position = UDim2.new(rel, 0, 0.5, 0)
				val.Text = tostring(v)
				if v ~= lastValue then
					lastValue = v
					if cb then task.spawn(cb, v) end
				end
			end

			hit.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					tw(thumb, EASE_FAST, {Size = UDim2.fromOffset(18, 18)})
					setFromX(i.Position.X)
				end
			end)
			local c1 = UserInputService.InputChanged:Connect(function(i)
				if not dragging then return end
				if i.UserInputType == Enum.UserInputType.MouseMovement
				or i.UserInputType == Enum.UserInputType.Touch then
					setFromX(i.Position.X)
				end
			end)
			local c2 = UserInputService.InputEnded:Connect(function(i)
				if dragging and (i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch) then
					dragging = false
					tw(thumb, EASE_SPRING, {Size = UDim2.fromOffset(14, 14)})
				end
			end)
			r.AncestryChanged:Connect(function(_, p)
				if not p then c1:Disconnect() c2:Disconnect() end
			end)

			local api = {Instance = r}
			function api:Set(v)
				v = math.clamp(v, min, max)
				lastValue = v
				local rel = (v-min)/math.max(max-min,1)
				fill.Size = UDim2.new(rel, 0, 1, 0)
				thumb.Position = UDim2.new(rel, 0, 0.5, 0)
				val.Text = tostring(v)
			end
			function api:Get() return lastValue end
			return api
		end

		function Tab:AddDropdown(text, options, cb)
			options = options or {}
			local current = options[1] or ""
			local r = rowBase(42)

			local l = Instance.new("TextLabel")
			l.BackgroundTransparency = 1
			l.Position = UDim2.new(0, 14, 0, 0)
			l.Size = UDim2.new(0.45, 0, 1, 0)
			l.Font = Enum.Font.GothamMedium
			l.TextSize = 12
			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextColor3 = T.Text
			l.Text = text
			l.ZIndex = 16
			l.Parent = r

			local pick = Instance.new("TextButton")
			pick.AnchorPoint = Vector2.new(1, 0.5)
			pick.Position = UDim2.new(1, -14, 0.5, 0)
			pick.Size = UDim2.fromOffset(150, 28)
			pick.BackgroundColor3 = T.BgDeep
			pick.BorderSizePixel = 0
			pick.AutoButtonColor = false
			pick.Text = ""
			pick.ZIndex = 16
			pick.Active = true
			pick.Parent = r
			corner(pick, UDim.new(0, 6))
			stroke(pick, T.Border, 0.4, 1)

			local pickLabel = Instance.new("TextLabel")
			pickLabel.BackgroundTransparency = 1
			pickLabel.Position = UDim2.new(0, 10, 0, 0)
			pickLabel.Size = UDim2.new(1, -28, 1, 0)
			pickLabel.Font = Enum.Font.GothamMedium
			pickLabel.TextSize = 11
			pickLabel.TextXAlignment = Enum.TextXAlignment.Left
			pickLabel.TextColor3 = T.Text
			pickLabel.Text = current
			pickLabel.ZIndex = 17
			pickLabel.Parent = pick

			local arrow = Instance.new("TextLabel")
			arrow.BackgroundTransparency = 1
			arrow.AnchorPoint = Vector2.new(1, 0.5)
			arrow.Position = UDim2.new(1, -8, 0.5, 0)
			arrow.Size = UDim2.fromOffset(14, 14)
			arrow.Font = Enum.Font.GothamBold
			arrow.TextSize = 11
			arrow.TextColor3 = T.Accent
			arrow.Text = "▾"
			arrow.ZIndex = 17
			arrow.Parent = pick

			local panel = Instance.new("Frame")
			panel.BackgroundColor3 = T.Surface
			panel.BorderSizePixel = 0
			panel.Visible = false
			panel.ZIndex = 220
			panel.Active = true
			panel.ClipsDescendants = true
			panel.Parent = overlayLayer
			corner(panel, UDim.new(0, 8))
			rainbowStroke(panel, 1.2, 0.2)

			local listScroll = Instance.new("ScrollingFrame")
			listScroll.Size = UDim2.fromScale(1,1)
			listScroll.BackgroundTransparency = 1
			listScroll.BorderSizePixel = 0
			listScroll.ScrollBarThickness = 2
			listScroll.ScrollBarImageColor3 = T.Accent
			listScroll.CanvasSize = UDim2.new(0,0,0,0)
			listScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
			listScroll.ElasticBehavior = Enum.ElasticBehavior.Never
			listScroll.ZIndex = 221
			listScroll.Active = true
			listScroll.Parent = panel
			local ll = Instance.new("UIListLayout")
			ll.Parent = listScroll
			ll.Padding = UDim.new(0, 2)
			local lp = Instance.new("UIPadding")
			lp.PaddingTop = UDim.new(0, 4)
			lp.PaddingBottom = UDim.new(0, 4)
			lp.PaddingLeft = UDim.new(0, 4)
			lp.PaddingRight = UDim.new(0, 4)
			lp.Parent = listScroll

			local optBtns = {}
			local opened = false
			local close, open

			close = function()
				if not opened then return end
				opened = false
				if panel.Parent then
					tw(panel, EASE_FAST, {Size = UDim2.fromOffset(panel.AbsoluteSize.X, 0)})
				end
				task.delay(0.16, function()
					if not opened and panel.Parent then panel.Visible = false end
				end)
			end

			open = function()
				if opened then return end
				opened = true
				local pickAbs = pick.AbsolutePosition
				local pickSize = pick.AbsoluteSize
				local screenSize = gui.AbsoluteSize
				local h = math.min(#options * 30 + 8, 180)
				local openUp = (screenSize.Y - pickAbs.Y - pickSize.Y) < h + 10
				local px = math.clamp(pickAbs.X, 4, screenSize.X - pickSize.X - 4)
				local py = openUp and (pickAbs.Y - h - 4) or (pickAbs.Y + pickSize.Y + 4)
				panel.Position = UDim2.fromOffset(px, py)
				panel.Size = UDim2.fromOffset(pickSize.X, 0)
				panel.Visible = true
				tw(panel, EASE_OUT, {Size = UDim2.fromOffset(pickSize.X, h)})
				arrow.Text = openUp and "▴" or "▾"
			end

			for _, opt in ipairs(options) do
				local b = Instance.new("TextButton")
				b.Size = UDim2.new(1, 0, 0, 28)
				b.BackgroundColor3 = T.BgDeep
				b.BackgroundTransparency = 1
				b.BorderSizePixel = 0
				b.AutoButtonColor = false
				b.Text = ""
				b.ZIndex = 222
				b.Active = true
				b.Parent = listScroll
				corner(b, UDim.new(0, 6))

				local ol = Instance.new("TextLabel")
				ol.BackgroundTransparency = 1
				ol.Position = UDim2.new(0, 10, 0, 0)
				ol.Size = UDim2.new(1, -28, 1, 0)
				ol.Font = Enum.Font.GothamMedium
				ol.TextSize = 11
				ol.TextXAlignment = Enum.TextXAlignment.Left
				ol.TextColor3 = T.Text
				ol.Text = opt
				ol.ZIndex = 223
				ol.Parent = b

				local check = Instance.new("TextLabel")
				check.BackgroundTransparency = 1
				check.AnchorPoint = Vector2.new(1, 0.5)
				check.Position = UDim2.new(1, -8, 0.5, 0)
				check.Size = UDim2.fromOffset(14, 14)
				check.Font = Enum.Font.GothamBold
				check.TextSize = 12
				check.TextColor3 = T.Accent
				check.Text = (opt == current) and "✓" or ""
				check.ZIndex = 223
				check.Parent = b

				b.MouseEnter:Connect(function() tw(b, EASE_FAST, {BackgroundTransparency = 0, BackgroundColor3 = T.SurfaceHover}) end)
				b.MouseLeave:Connect(function() tw(b, EASE_FAST, {BackgroundTransparency = 1}) end)
				b.MouseButton1Click:Connect(function()
					current = opt
					pickLabel.Text = opt
					for _, ob in ipairs(optBtns) do
						ob.check.Text = (ob.opt == opt) and "✓" or ""
					end
					close()
					if cb then task.spawn(cb, opt) end
				end)
				table.insert(optBtns, {opt = opt, check = check})
			end

			pick.MouseButton1Click:Connect(function()
				if opened then close() else open() end
			end)

			table.insert(globalClickListeners, function(i)
				if not opened or not panel.Parent then return end
				local ax, ay = i.Position.X, i.Position.Y
				local p1, p2 = panel.AbsolutePosition, panel.AbsolutePosition + panel.AbsoluteSize
				local k1, k2 = pick.AbsolutePosition, pick.AbsolutePosition + pick.AbsoluteSize
				local inP = ax >= p1.X and ax <= p2.X and ay >= p1.Y and ay <= p2.Y
				local inK = ax >= k1.X and ax <= k2.X and ay >= k1.Y and ay <= k2.Y
				if not inP and not inK then close() end
			end)

			table.insert(Window._dropdowns, close)

			local api = {Instance = r}
			function api:Get() return current end
			function api:Set(v)
				current = v; pickLabel.Text = v
				for _, ob in ipairs(optBtns) do ob.check.Text = (ob.opt == v) and "✓" or "" end
			end
			return api
		end

		-- 脚本执行器
		function Tab:AddExecutor()
			self:AddSection("LUA EXECUTOR")
			local r = rowBase(200)

			local box = Instance.new("TextBox")
			box.Position = UDim2.new(0, 12, 0, 10)
			box.Size = UDim2.new(1, -24, 1, -50)
			box.BackgroundColor3 = T.BgDeep
			box.BorderSizePixel = 0
			box.Font = Enum.Font.Code
			box.TextSize = 12
			box.TextColor3 = Color3.fromRGB(180, 255, 180)
			box.PlaceholderText = "-- 在此粘贴 Lua 代码"
			box.PlaceholderColor3 = T.TextMuted
			box.Text = ""
			box.MultiLine = true
			box.TextXAlignment = Enum.TextXAlignment.Left
			box.TextYAlignment = Enum.TextYAlignment.Top
			box.TextWrapped = true
			box.ClearTextOnFocus = false
			box.ZIndex = 16
			box.Parent = r
			corner(box, UDim.new(0, 6))
			stroke(box, T.Border, 0.4, 1)
			local bp = Instance.new("UIPadding")
			bp.PaddingTop = UDim.new(0, 8)
			bp.PaddingLeft = UDim.new(0, 10)
			bp.PaddingRight = UDim.new(0, 10)
			bp.Parent = box

			-- 按钮栏
			local btnRow = Instance.new("Frame")
			btnRow.Position = UDim2.new(0, 12, 1, -36)
			btnRow.Size = UDim2.new(1, -24, 0, 28)
			btnRow.BackgroundTransparency = 1
			btnRow.ZIndex = 16
			btnRow.Parent = r

			local function execBtn(text, color, x, w, fn)
				local b = Instance.new("TextButton")
				b.Position = UDim2.fromOffset(x, 0)
				b.Size = UDim2.fromOffset(w, 28)
				b.BackgroundColor3 = color
				b.BorderSizePixel = 0
				b.AutoButtonColor = false
				b.Font = Enum.Font.GothamBold
				b.TextSize = 11
				b.Text = text
				b.TextColor3 = Color3.fromRGB(255,255,255)
				b.ZIndex = 17
				b.Parent = btnRow
				corner(b, UDim.new(0, 6))
				local sc = Instance.new("UIScale")
				sc.Parent = b
				b.MouseEnter:Connect(function() tw(sc, EASE_FAST, {Scale = 1.05}) end)
				b.MouseLeave:Connect(function() tw(sc, EASE_FAST, {Scale = 1}) end)
				b.MouseButton1Click:Connect(fn)
				return b
			end

			execBtn("▶ EXECUTE", T.Accent, 0, 100, function()
				local code = box.Text
				if code == "" then DynamicUI:Notify("脚本为空", "warn") return end
				if not loadstring then DynamicUI:Notify("不支持 loadstring", "error", 3) return end
				local fn, err = loadstring(code)
				if not fn then DynamicUI:Notify("语法错误: "..tostring(err), "error", 4) return end
				local ok, runErr = pcall(fn)
				if ok then DynamicUI:Notify("执行成功", "success")
				else DynamicUI:Notify("运行错误: "..tostring(runErr), "error", 4) end
			end)

			execBtn("CLEAR", Color3.fromRGB(228, 174, 70), 108, 70, function()
				box.Text = ""
			end)

			execBtn("LOAD URL", Color3.fromRGB(86, 150, 200), 186, 90, function()
				local url = box.Text
				if not url:match("^https?://") then DynamicUI:Notify("请输入 URL", "warn") return end
				if not game.HttpGet then DynamicUI:Notify("不支持 HttpGet", "error") return end
				local ok, content = pcall(function() return game:HttpGet(url) end)
				if not ok then DynamicUI:Notify("加载失败", "error") return end
				box.Text = content
				DynamicUI:Notify("已加载 "..#content.." 字符", "success")
			end)

			return {Instance = r}
		end

		if not Window.current then
			task.delay(0.05, function() switchTab(name) end)
		end
		return Tab
	end

	------------------------------------------------------------------
	-- 公开 API
	------------------------------------------------------------------
	function Window:SelectTab(name) if Window.tabs[name] then switchTab(name) end end
	function Window:SetTitle(text) logoTitle.Text = text:upper(); iTitle.Text = text end
	function Window:Show()
		window.Visible = true; glow.Visible = true
		tw(windowScale, EASE_SPRING, {Scale = 1})
		tw(window, EASE_OUT, {BackgroundTransparency = 0})
		tw(glow, EASE_OUT, {ImageTransparency = 0.7})
	end
	function Window:Hide()
		tw(windowScale, EASE_FAST, {Scale = 0.9})
		tw(window, EASE_OUT, {BackgroundTransparency = 1})
		tw(glow, EASE_OUT, {ImageTransparency = 1})
		task.delay(0.3, function()
			if window.Parent then window.Visible = false end
			glow.Visible = false
		end)
	end
	function Window:Toggle() if window.Visible then self:Hide() else self:Show() end end
	function Window:Bind(keycode)
		UserInputService.InputBegan:Connect(function(input, gp)
			if not gp and input.KeyCode == keycode then self:Toggle() end
		end)
	end
	function Window:Destroy()
		if window.Parent then window:Destroy() end
		if island.Parent then island:Destroy() end
		if overlayLayer.Parent then overlayLayer:Destroy() end
		if glow.Parent then glow:Destroy() end
	end

	local minimized = false
	setMin = function(s)
		minimized = s
		if s then
			tw(windowScale, EASE_FAST, {Scale = 0.85})
			tw(window, EASE_OUT, {BackgroundTransparency = 1})
			tw(glow, EASE_OUT, {ImageTransparency = 1})
			task.delay(0.3, function()
				if minimized and window.Parent then
					window.Visible = false
					glow.Visible = false
				end
			end)
			island.Visible = true
			island.Size = UDim2.fromOffset(40, 40)
			island.BackgroundTransparency = 1
			tw(island, EASE_SPRING, {Size = cfg.IslandSize, BackgroundTransparency = 0})
		else
			window.Visible = true; glow.Visible = true
			windowScale.Scale = 0.85
			window.BackgroundTransparency = 1
			tw(windowScale, EASE_SPRING, {Scale = 1})
			tw(window, EASE_OUT, {BackgroundTransparency = 0})
			tw(glow, EASE_OUT, {ImageTransparency = 0.7})
			tw(island, EASE_OUT, {Size = UDim2.fromOffset(40, 40), BackgroundTransparency = 1})
			task.delay(0.3, function() if not minimized and island.Parent then island.Visible = false end end)
		end
	end

	btnMin.MouseButton1Click:Connect(function() setMin(true) end)
	btnClose.MouseButton1Click:Connect(function()
		tw(windowScale, EASE_FAST, {Scale = 0.7})
		tw(window, EASE_OUT, {BackgroundTransparency = 1})
		tw(glow, EASE_OUT, {ImageTransparency = 1})
		tw(island, EASE_OUT, {Size = UDim2.fromOffset(0,0), BackgroundTransparency = 1})
		task.wait(0.36)
		Window:Destroy()
	end)

	RunService.RenderStepped:Connect(function()
		if glow.Parent and window.Parent and window.Visible then
			glow.Position = window.Position
			glow.Size = UDim2.fromOffset(window.AbsoluteSize.X + 120, window.AbsoluteSize.Y + 120)
		end
	end)

	showLoader(gui, function()
		window.Position = UDim2.new(0.5, 0, 0.5, 0)
		window.BackgroundTransparency = 1
		windowScale.Scale = 0.85
		window.Visible = true
		glow.Visible = true
		glow.ImageTransparency = 1
		tw(windowScale, EASE_SPRING, {Scale = 1})
		tw(window, EASE_OUT, {BackgroundTransparency = 0})
		tw(glow, EASE_SLOW, {ImageTransparency = 0.7})
		task.wait()
		clampPosition(window, gui.AbsoluteSize)
	end)

	gui:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
		if window.Visible then clampPosition(window, gui.AbsoluteSize) end
		if island.Visible then clampPosition(island, gui.AbsoluteSize) end
	end)

	return Window
end

return DynamicUI
