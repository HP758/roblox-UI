			t.indicator.BackgroundTransparency = active and 0 or 1
			t.page.Visible = active
			if active then
				t.page.Position = UDim2.new(0, 0, 0, 8)
				t.page.GroupTransparency = 1
				tw(t.page, EASE_OUT, {Position = UDim2.new(0,0,0,0), GroupTransparency = 0})
			end
		end
		Window.current = name
	end

