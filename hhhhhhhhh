		function Tab:AddSlider(text, min, max, default, cb)
			min = min or 0; max = max or 100
			default = math.clamp(default or min, min, max)
			local r = rowBase(58)

			local l = Instance.new("TextLabel")
			l.BackgroundTransparency = 1
			l.Position = UDim2.new(0, 12, 0, 6)
			l.Size = UDim2.new(1, -24, 0, 16)
			l.Font = Enum.Font.Gotham
			l.TextSize = 12
			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextColor3 = T.Text
			l.Text = text
			l.ZIndex = 16
			l.Parent = r

			local val = Instance.new("TextLabel")
			val.BackgroundTransparency = 1
			val.AnchorPoint = Vector2.new(1, 0)
			val.Position = UDim2.new(1, -12, 0, 6)
			val.Size = UDim2.fromOffset(60, 16)
			val.Font = Enum.Font.GothamSemibold
			val.TextSize = 12
			val.TextXAlignment = Enum.TextXAlignment.Right
			val.TextColor3 = T.Accent
			val.Text = tostring(default)
			val.ZIndex = 16
			val.Parent = r

			local track = Instance.new("Frame")
			track.Position = UDim2.new(0, 12, 1, -18)
			track.Size = UDim2.new(1, -24, 0, 4)
			track.BackgroundColor3 = T.Track
			track.BorderSizePixel = 0
			track.ZIndex = 16
			track.Parent = r
			corner(track, UDim.new(1,0))

			local fill = Instance.new("Frame")
			fill.Size = UDim2.new((default-min)/math.max(max-min,1), 0, 1, 0)
			fill.BackgroundColor3 = T.Accent
			fill.BorderSizePixel = 0
			fill.ZIndex = 17
			fill.Parent = track
			corner(fill, UDim.new(1,0))

			-- 拇指
			local thumb = Instance.new("Frame")
			thumb.AnchorPoint = Vector2.new(0.5, 0.5)
			thumb.Position = UDim2.new((default-min)/math.max(max-min,1), 0, 0.5, 0)
			thumb.Size = UDim2.fromOffset(14, 14)
			thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
			thumb.BorderSizePixel = 0
			thumb.ZIndex = 18
			thumb.Parent = track
			corner(thumb, UDim.new(1,0))
			stroke(thumb, T.Accent, 0, 1.5)

			-- 击中区（高一点，方便点）
			local hit = Instance.new("TextButton")
			hit.BackgroundTransparency = 1
			hit.Text = ""
			hit.Size = UDim2.new(1, 20, 0, 28)
			hit.Position = UDim2.new(0, -10, 0.5, -14)
			hit.ZIndex = 19
			hit.AutoButtonColor = false
			hit.Active = true
			hit.Parent = track

			-- 关键修复：用全局输入 + RenderStepped 采样，不丢帧
			local dragging = false
			local lastValue = default
			local activeInput

			local function setFromX(x)
				local rel = math.clamp((x - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
				local v = math.floor(min + (max - min) * rel + 0.5)
				fill.Size = UDim2.new(rel, 0, 1, 0)
				thumb.Position = UDim2.new(rel, 0, 0.5, 0)
				val.Text = tostring(v)
				if v ~= lastValue then
					lastValue = v
					if cb then task.spawn(cb, v) end
				end
			end

			hit.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					activeInput = i
					tw(thumb, EASE_FAST, {Size = UDim2.fromOffset(16, 16)})
					setFromX(i.Position.X)
				end
			end)

			-- 全局监听，避免鼠标快移出 hit 区造成断触
			local conn1 = UserInputService.InputChanged:Connect(function(i)
				if not dragging then return end
				if i.UserInputType == Enum.UserInputType.MouseMovement
				or i.UserInputType == Enum.UserInputType.Touch then
					setFromX(i.Position.X)
				end
			end)

			-- RenderStepped 兜底（即使 InputChanged 没触发也能跟手）
			local conn2 = RunService.RenderStepped:Connect(function()
				if dragging then
					local mp = UserInputService:GetMouseLocation()
					-- 用鼠标位置（PC 主要用这个），Touch 由 InputChanged 提供
					if activeInput and activeInput.UserInputType == Enum.UserInputType.MouseButton1 then
						setFromX(mp.X)
					end
				end
			end)

			UserInputService.InputEnded:Connect(function(i)
				if dragging and (i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch) then
					dragging = false
					activeInput = nil
					tw(thumb, EASE_FAST, {Size = UDim2.fromOffset(14, 14)})
				end
			end)

			r.AncestryChanged:Connect(function(_, parent)
				if not parent then
					conn1:Disconnect()
					conn2:Disconnect()
				end
			end)
		end

		function Tab:AddDropdown(text, options, cb)
			options = options or {}
			local current = options[1] or ""
			local r = rowBase(40)

			local l = Instance.new("TextLabel")
			l.BackgroundTransparency = 1
			l.Position = UDim2.new(0, 12, 0, 0)
			l.Size = UDim2.new(0.45, 0, 1, 0)
