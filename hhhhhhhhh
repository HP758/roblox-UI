	local function moveIndicator(btn)
		if not btn then return end
		globalIndicator.Visible = true
		local pos = btn.AbsolutePosition.X - tabBar.AbsolutePosition.X
		local size = btn.AbsoluteSize.X
		tw(globalIndicator, EASE_OUT, {
			Position = UDim2.new(0, pos + size/2 - 12, 1, -3),
			Size = UDim2.fromOffset(24, 2),
		})
	end

	local function switchTab(name)
		if Window.current == name then return end
		for _, fn in ipairs(Window._dropdowns) do pcall(fn) end

		for n, t in pairs(Window.tabs) do
			local active = (n == name)
			tw(t.button, EASE_FAST, {
				BackgroundColor3 = active and T.Surface or T.SurfaceAlt,
				BackgroundTransparency = active and 0 or 1,
				TextColor3 = active and T.Text or T.TextSub,
			})

			if active then
				moveIndicator(t.button)
				t.page.Visible = true
				for i, child in ipairs(t.page:GetChildren()) do
					if (child:IsA("Frame") or child:IsA("TextLabel"))
					and not child:IsA("UIListLayout")
					and not child:IsA("UIPadding")
					and not child:IsA("UICorner")
					and not child:IsA("UIStroke") then
						local origPos = child.Position
						local origTrans = child:IsA("Frame") and child.BackgroundTransparency or 0
						child.Position = origPos + UDim2.fromOffset(0, 8)
						if child:IsA("Frame") then child.BackgroundTransparency = 1 end
						task.delay((i-1) * 0.02, function()
							if not child.Parent then return end
							tw(child, EASE_OUT, {Position = origPos})
							if child:IsA("Frame") then
								tw(child, EASE_OUT, {BackgroundTransparency = origTrans})
							end
						end)
					end
				end
			else
				t.page.Visible = false
			end
		end
		Window.current = name
	end

