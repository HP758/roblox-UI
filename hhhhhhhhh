local function ripple(parent, x, y, color)
	local r = Instance.new("Frame")
	r.AnchorPoint = Vector2.new(0.5, 0.5)
	r.Position = UDim2.fromOffset(x, y)
	r.Size = UDim2.fromOffset(0, 0)
	r.BackgroundColor3 = color or Color3.fromRGB(255,255,255)
	r.BackgroundTransparency = 0.6
	r.BorderSizePixel = 0
	r.ZIndex = (parent.ZIndex or 0) + 1
	r.Parent = parent
	corner(r, UDim.new(1,0))
	tw(r, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {
		Size = UDim2.fromOffset(180, 180),
		BackgroundTransparency = 1,
	})
	task.delay(0.45, function() if r.Parent then r:Destroy() end end)
end

