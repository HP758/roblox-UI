local function makeResizable(window, gui, minSize, maxSize)
	local handle = Instance.new("Frame")
	handle.AnchorPoint = Vector2.new(1, 1)
	handle.Position = UDim2.new(1, 0, 1, 0)
	handle.Size = UDim2.fromOffset(16, 16)
	handle.BackgroundTransparency = 1
	handle.ZIndex = 100
	handle.Active = true
	handle.Parent = window

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.fromScale(1,1)
	btn.BackgroundTransparency = 1
	btn.Text = ""
	btn.AutoButtonColor = false
	btn.ZIndex = 101
	btn.Parent = handle

	-- 视觉指示
	for i = 1, 3 do
		local line = Instance.new("Frame")
		line.AnchorPoint = Vector2.new(1, 1)
		line.Position = UDim2.new(1, -2 - (i-1)*3, 1, -2)
		line.Size = UDim2.fromOffset(2 + (i-1)*3, 2)
		line.BackgroundColor3 = Color3.fromRGB(150,150,150)
		line.BackgroundTransparency = 0.5
		line.BorderSizePixel = 0
		line.ZIndex = 100
		line.Parent = handle
	end

	local resizing = false
	local startPos, startSize

	btn.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch then
			resizing = true
			startPos = i.Position
			startSize = window.AbsoluteSize
		end
	end)

	UserInputService.InputChanged:Connect(function(i)
		if not resizing then return end
		if i.UserInputType == Enum.UserInputType.MouseMovement
		or i.UserInputType == Enum.UserInputType.Touch then
			local d = i.Position - startPos
			local newW = math.clamp(startSize.X + d.X, minSize.X, maxSize.X)
			local newH = math.clamp(startSize.Y + d.Y, minSize.Y, maxSize.Y)
			window.Size = UDim2.fromOffset(newW, newH)
		end
	end)

	UserInputService.InputEnded:Connect(function(i)
		if resizing and (i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch) then
			resizing = false
		end
	end)
end

