			l.TextSize = 12
			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextColor3 = T.Text
			l.Text = text
			l.ZIndex = 16
			l.Parent = r
			subscribe(function(t) l.TextColor3 = t.Text end)

			local box = Instance.new("TextBox")
			box.AnchorPoint = Vector2.new(1, 0.5)
			box.Position = UDim2.new(1, -14, 0.5, 0)
			box.Size = UDim2.fromOffset(170, 28)
			box.BackgroundColor3 = T.BgDeep
			box.BorderSizePixel = 0
			box.Font = Enum.Font.Gotham
			box.TextSize = 12
			box.TextColor3 = T.Text
			box.PlaceholderText = placeholder or ""
			box.PlaceholderColor3 = T.TextMuted
			box.Text = ""
			box.ClearTextOnFocus = false
			box.ZIndex = 16
			box.Parent = r
			corner(box, UDim.new(0, 6))
			local bs = stroke(box, T.Border, 0.4, 1)
			subscribe(function(t)
				box.BackgroundColor3 = t.BgDeep
				box.TextColor3 = t.Text
				box.PlaceholderColor3 = t.TextMuted
				bs.Color = t.Border
			end)
			local p = Instance.new("UIPadding")
			p.PaddingLeft = UDim.new(0, 10)
			p.PaddingRight = UDim.new(0, 10)
			p.Parent = box

			box.Focused:Connect(function() tw(bs, EASE_FAST, {Color = T.Accent, Transparency = 0}) end)
			box.FocusLost:Connect(function()
				tw(bs, EASE_FAST, {Color = T.Border, Transparency = 0.4})
				if cb then task.spawn(cb, box.Text) end
			end)

			local api = {Instance = r}
			function api:Set(t) box.Text = t end
			function api:Get() return box.Text end
			return api
		end

		function Tab:AddKeybind(text, defaultKey, cb)
			local r = rowBase(42)
			local key = defaultKey
			local listening = false

			local l = Instance.new("TextLabel")
			l.BackgroundTransparency = 1
			l.Position = UDim2.new(0, 14, 0, 0)
			l.Size = UDim2.new(1, -110, 1, 0)
			l.Font = Enum.Font.GothamMedium
			l.TextSize = 12
			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextColor3 = T.Text
			l.Text = text
			l.ZIndex = 16
			l.Parent = r
			subscribe(function(t) l.TextColor3 = t.Text end)

			local btn = Instance.new("TextButton")
			btn.AnchorPoint = Vector2.new(1, 0.5)
			btn.Position = UDim2.new(1, -14, 0.5, 0)
			btn.Size = UDim2.fromOffset(86, 28)
			btn.BackgroundColor3 = T.BgDeep
			btn.BorderSizePixel = 0
			btn.AutoButtonColor = false
			btn.Font = Enum.Font.GothamSemibold
			btn.TextSize = 11
			btn.TextColor3 = T.Text
			btn.Text = key and key.Name or "未绑定"
			btn.ZIndex = 16
			btn.Active = true
			btn.Parent = r
			corner(btn, UDim.new(0, 6))
			local bs = stroke(btn, T.Border, 0.4, 1)
			subscribe(function(t)
				btn.BackgroundColor3 = t.BgDeep
				btn.TextColor3 = t.Text
				bs.Color = t.Border
			end)

			btn.MouseButton1Click:Connect(function()
				listening = true
				btn.Text = "按下..."
				tw(bs, EASE_FAST, {Color = T.Accent, Transparency = 0})
			end)
			UserInputService.InputBegan:Connect(function(input, gp)
				if listening and input.UserInputType == Enum.UserInputType.Keyboard then
					listening = false
					key = input.KeyCode
					btn.Text = key.Name
					tw(bs, EASE_FAST, {Color = T.Border, Transparency = 0.4})
				elseif key and not gp and not listening
					and input.UserInputType == Enum.UserInputType.Keyboard
					and input.KeyCode == key then
					if cb then task.spawn(cb) end
				end
			end)
			local api = {Instance = r}
			function api:Set(k) key = k; btn.Text = k.Name end
			function api:Get() return key end
			return api
		end

		-- 执行器
		function Tab:AddExecutor()
			self:AddSection("脚本执行器")
			local r = rowBase(220)

			local box = Instance.new("TextBox")
			box.Position = UDim2.new(0, 12, 0, 10)
			box.Size = UDim2.new(1, -24, 1, -56)
			box.BackgroundColor3 = T.BgDeep
			box.BorderSizePixel = 0
			box.Font = Enum.Font.Code
			box.TextSize = 12
			box.TextColor3 = Color3.fromRGB(180,255,180)
			box.PlaceholderText = "-- 在此粘贴 Lua 代码"
			box.PlaceholderColor3 = T.TextMuted
			box.Text = ""
			box.MultiLine = true
			box.TextXAlignment = Enum.TextXAlignment.Left
			box.TextYAlignment = Enum.TextYAlignment.Top
			box.TextWrapped = true
			box.ClearTextOnFocus = false
			box.ZIndex = 16
			box.Parent = r
			corner(box, UDim.new(0, 6))
			local bs = stroke(box, T.Border, 0.4, 1)
			subscribe(function(t)
				box.BackgroundColor3 = t.BgDeep
				box.PlaceholderColor3 = t.TextMuted
				bs.Color = t.Border
			end)
			local bp = Instance.new("UIPadding")
			bp.PaddingTop = UDim.new(0, 8)
			bp.PaddingLeft = UDim.new(0, 10)
			bp.PaddingRight = UDim.new(0, 10)
			bp.Parent = box

			local btnRow = Instance.new("Frame")
			btnRow.Position = UDim2.new(0, 12, 1, -40)
			btnRow.Size = UDim2.new(1, -24, 0, 32)
			btnRow.BackgroundTransparency = 1
			btnRow.ZIndex = 16
			btnRow.Parent = r

			local function execBtn(text, color, x, w, fn)
				local b = Instance.new("TextButton")
				b.Position = UDim2.fromOffset(x, 0)
				b.Size = UDim2.fromOffset(w, 30)
				b.BackgroundColor3 = color
				b.BorderSizePixel = 0
				b.AutoButtonColor = false
				b.Font = Enum.Font.GothamBold
				b.TextSize = 11
				b.Text = text
				b.TextColor3 = Color3.fromRGB(255,255,255)
				b.ZIndex = 17
				b.Parent = btnRow
				corner(b, UDim.new(0, 6))
				local sc = Instance.new("UIScale")
				sc.Parent = b
				b.MouseEnter:Connect(function() tw(sc, EASE_FAST, {Scale = 1.05}) end)
				b.MouseLeave:Connect(function() tw(sc, EASE_FAST, {Scale = 1}) end)
				b.MouseButton1Click:Connect(fn)
				return b
			end

			local execB = execBtn("▶ 执行", T.Accent, 0, 100, function()
				local code = box.Text
				if code == "" then DynamicUI:Notify("脚本为空", "warn") return end
				if not loadstring then DynamicUI:Notify("不支持 loadstring", "error", 3) return end
				local fn, err = loadstring(code)
				if not fn then DynamicUI:Notify("语法错误: "..tostring(err), "error", 4) return end
				local ok, runErr = pcall(fn)
				if ok then DynamicUI:Notify("执行成功", "success")
				else DynamicUI:Notify("运行错误: "..tostring(runErr), "error", 4) end
			end)
			subscribe(function(t) execB.BackgroundColor3 = t.Accent end)

			execBtn("清空", Color3.fromRGB(228,174,70), 108, 70, function()
				box.Text = ""
				DynamicUI:Notify("已清空", "info")
			end)

			execBtn("从链接加载", Color3.fromRGB(86,150,200), 186, 100, function()
				local url = box.Text
				if not url:match("^https?://") then DynamicUI:Notify("请输入 URL", "warn") return end
				if not game.HttpGet then DynamicUI:Notify("不支持 HttpGet", "error") return end
				local ok, content = pcall(function() return game:HttpGet(url) end)
				if not ok then DynamicUI:Notify("加载失败", "error") return end
				box.Text = content
				DynamicUI:Notify("已加载 "..#content.." 字符", "success")
			end)

			return {Instance = r}
		end

		if not Window.current then
			task.delay(0.05, function() switchTab(name) end)
		end
		return Tab
	end

	------------------------------------------------------------------
	-- 公开 API
	------------------------------------------------------------------
	function Window:SelectTab(name) if Window.tabs[name] then switchTab(name) end end
	function Window:SetTitle(text) logoTitle.Text = text; iTitle.Text = text end

	function Window:SetTheme(name)
		local newT = THEMES[name]
		if not newT then return end
		for k, v in pairs(newT) do T[k] = v end
		notifyAll()
		DynamicUI:Notify("主题已切换为 " .. name, "info")
	end

	function Window:SetAccent(color)
		T.Accent = color
		-- 自动算出 AccentSoft（变暗一点）
		T.AccentSoft = Color3.new(color.R * 0.3, color.G * 0.3, color.B * 0.3)
		notifyAll()
		DynamicUI:Notify("主题色已更改", "rainbow")
	end

	function Window:Show()
		window.Visible = true; glow.Visible = true
		tw(windowScale, EASE_SPRING, {Scale = 1})
		tw(window, EASE_OUT, {BackgroundTransparency = 0})
		tw(glow, EASE_OUT, {ImageTransparency = 0.7})
	end
	function Window:Hide()
		tw(windowScale, EASE_FAST, {Scale = 0.9})
		tw(window, EASE_OUT, {BackgroundTransparency = 1})
		tw(glow, EASE_OUT, {ImageTransparency = 1})
		task.delay(0.3, function()
			if window.Parent then window.Visible = false end
			glow.Visible = false
		end)
	end
	function Window:Toggle() if window.Visible then self:Hide() else self:Show() end end
	function Window:Bind(keycode)
		UserInputService.InputBegan:Connect(function(input, gp)
			if not gp and input.KeyCode == keycode then self:Toggle() end
		end)
	end
	function Window:Destroy()
		if window.Parent then window:Destroy() end
		if island.Parent then island:Destroy() end
		if overlayLayer.Parent then overlayLayer:Destroy() end
		if glow.Parent then glow:Destroy() end
	end

	local minimized = false
	setMin = function(s)
		minimized = s
		if s then
			tw(windowScale, EASE_FAST, {Scale = 0.85})
			tw(window, EASE_OUT, {BackgroundTransparency = 1})
			tw(glow, EASE_OUT, {ImageTransparency = 1})
			task.delay(0.3, function()
				if minimized and window.Parent then
					window.Visible = false; glow.Visible = false
				end
			end)
			island.Visible = true
			island.Size = UDim2.fromOffset(40, 40)
			island.BackgroundTransparency = 1
			tw(island, EASE_SPRING, {Size = cfg.IslandSize, BackgroundTransparency = 0})
		else
			window.Visible = true; glow.Visible = true
			windowScale.Scale = 0.85
			window.BackgroundTransparency = 1
			tw(windowScale, EASE_SPRING, {Scale = 1})
			tw(window, EASE_OUT, {BackgroundTransparency = 0})
			tw(glow, EASE_OUT, {ImageTransparency = 0.7})
			tw(island, EASE_OUT, {Size = UDim2.fromOffset(40, 40), BackgroundTransparency = 1})
			task.delay(0.3, function() if not minimized and island.Parent then island.Visible = false end end)
		end
	end

	btnMin.MouseButton1Click:Connect(function() setMin(true) end)
	btnClose.MouseButton1Click:Connect(function()
		tw(windowScale, EASE_FAST, {Scale = 0.7})
		tw(window, EASE_OUT, {BackgroundTransparency = 1})
		tw(glow, EASE_OUT, {ImageTransparency = 1})
		tw(island, EASE_OUT, {Size = UDim2.fromOffset(0,0), BackgroundTransparency = 1})
		task.wait(0.36)
		Window:Destroy()
	end)

	RunService.RenderStepped:Connect(function()
		if glow.Parent and window.Parent and window.Visible then
			glow.Position = window.Position
			glow.Size = UDim2.fromOffset(window.AbsoluteSize.X + 140, window.AbsoluteSize.Y + 140)
		end
	end)

	showLoader(gui, T.Accent, function()
		window.Position = UDim2.new(0.5, 0, 0.5, 0)
		window.BackgroundTransparency = 1
		windowScale.Scale = 0.85
		window.Visible = true
		glow.Visible = true
		glow.ImageTransparency = 1
		tw(windowScale, EASE_SPRING, {Scale = 1})
		tw(window, EASE_OUT, {BackgroundTransparency = 0})
		tw(glow, EASE_SLOW, {ImageTransparency = 0.7})
		task.wait()
		clampPosition(window, gui.AbsoluteSize)
	end)

	gui:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
		if window.Visible then clampPosition(window, gui.AbsoluteSize) end
		if island.Visible then clampPosition(island, gui.AbsoluteSize) end
	end)

	return Window
end

return DynamicUI
