	local holder = ensureNotifyHolder(gui)

	local colors = {
		success = Color3.fromRGB(80, 220, 140),
		warn    = Color3.fromRGB(245, 180, 70),
		error   = Color3.fromRGB(240, 90, 90),
		info    = Color3.fromRGB(140, 100, 255),
		rainbow = nil,
	}
	local accent = colors[kind] or colors.info

	local wrap = Instance.new("Frame")
	wrap.Size = UDim2.fromOffset(270, 60)
	wrap.BackgroundTransparency = 1
	wrap.ZIndex = 1001
	wrap.Parent = holder

	local card = Instance.new("TextButton")
	card.AutoButtonColor = false
	card.Text = ""
	card.Position = UDim2.fromOffset(80, 0)
	card.Size = UDim2.fromOffset(270, 56)
	card.BackgroundColor3 = T.Surface
	card.BackgroundTransparency = 1
	card.BorderSizePixel = 0
	card.ZIndex = 1001
	card.Parent = wrap
	corner(card, UDim.new(0, 10))

	if kind == "rainbow" then
		rainbowStroke(card, 1.5, 0)
	else
		stroke(card, accent or T.Border, 0.3, 1)
	end

	local strip = Instance.new("Frame")
	strip.Size = UDim2.new(0, 0, 1, -18)
	strip.Position = UDim2.new(0, 10, 0, 9)
	strip.BackgroundColor3 = accent or T.Accent
	strip.BorderSizePixel = 0
	strip.ZIndex = 1002
	strip.Parent = card
	corner(strip, UDim.new(1,0))

	local iconBg = Instance.new("Frame")
	iconBg.BackgroundColor3 = (accent or T.Accent)
	iconBg.BackgroundTransparency = 0.85
	iconBg.Position = UDim2.new(0, 20, 0.5, -12)
	iconBg.Size = UDim2.fromOffset(24, 24)
	iconBg.BorderSizePixel = 0
	iconBg.ZIndex = 1002
	iconBg.Parent = card
	corner(iconBg, UDim.new(0, 6))

	local icon = Instance.new("TextLabel")
	icon.BackgroundTransparency = 1
	icon.Size = UDim2.fromScale(1,1)
	icon.Font = Enum.Font.GothamBold
	icon.TextSize = 13
	icon.TextColor3 = accent or T.Accent
	icon.Text = ({success="✓",warn="!",error="✕",info="i",rainbow="✦"})[kind] or "i"
	icon.ZIndex = 1003
	icon.Parent = iconBg

	local msg = Instance.new("TextLabel")
	msg.BackgroundTransparency = 1
	msg.Position = UDim2.new(0, 54, 0, 0)
	msg.Size = UDim2.new(1, -64, 1, -6)
	msg.Font = Enum.Font.GothamMedium
	msg.TextSize = 12
	msg.TextXAlignment = Enum.TextXAlignment.Left
	msg.TextColor3 = T.Text
	msg.TextTransparency = 1
	msg.Text = text
	msg.TextWrapped = true
	msg.ZIndex = 1003
	msg.Parent = card

	local progress = Instance.new("Frame")
	progress.Size = UDim2.new(1, 0, 0, 2)
	progress.AnchorPoint = Vector2.new(0, 1)
	progress.Position = UDim2.new(0, 0, 1, 0)
	progress.BackgroundColor3 = accent or T.Accent
	progress.BackgroundTransparency = 0.3
	progress.BorderSizePixel = 0
	progress.ZIndex = 1003
	progress.Parent = card

