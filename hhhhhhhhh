local function tw(obj, info, props)
	if not obj or not obj.Parent then return end
	local t = TweenService:Create(obj, info, props); t:Play(); return t
end

local function corner(p, r)
	local c = Instance.new("UICorner")
	c.CornerRadius = r or UDim.new(0, 10)
	c.Parent = p; return c
end

local function stroke(p, color, trans, thick)
	local s = Instance.new("UIStroke")
	s.Color = color or Color3.fromRGB(80,80,100)
	s.Transparency = trans or 0.3
	s.Thickness = thick or 1
	s.Parent = p; return s
end

-- 全局彩虹色管理：所有彩虹边框共用一个旋转值,统一同步
local RAINBOW = {
	rotation = 0,
	gradients = {},  -- 已注册的渐变实例
}

local function makeRainbowSequence()
	return ColorSequence.new({
		ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 80, 180)),
		ColorSequenceKeypoint.new(0.20, Color3.fromRGB(180, 100, 255)),
		ColorSequenceKeypoint.new(0.40, Color3.fromRGB(80, 180, 255)),
		ColorSequenceKeypoint.new(0.60, Color3.fromRGB(80, 255, 180)),
		ColorSequenceKeypoint.new(0.80, Color3.fromRGB(255, 220, 80)),
		ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 80, 180)),
	})
end

-- 关键：真·彩虹流光边框
local function rainbowBorder(parent, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Thickness = thickness or 1.8
	s.Transparency = transparency or 0
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.LineJoinMode = Enum.LineJoinMode.Round
	s.Parent = parent

	local g = Instance.new("UIGradient")
	g.Color = makeRainbowSequence()
	g.Rotation = RAINBOW.rotation
	g.Parent = s

	table.insert(RAINBOW.gradients, g)
	return s, g
end

-- 全局旋转驱动（只跑一次）
task.spawn(function()
	while true do
		RAINBOW.rotation = (RAINBOW.rotation + 1.2) % 360
		-- 清理已销毁的
		for i = #RAINBOW.gradients, 1, -1 do
			local g = RAINBOW.gradients[i]
			if not g.Parent then
				table.remove(RAINBOW.gradients, i)
			else
				g.Rotation = RAINBOW.rotation
			end
		end
		task.wait()
	end
end)

-- 彩虹文字色
local function rainbowText(label)
	local g = Instance.new("UIGradient")
	g.Color = makeRainbowSequence()
	g.Rotation = 0
	g.Parent = label
	table.insert(RAINBOW.gradients, g)
	return g
end

local function clampPosition(target, screenSize)
	if not target or not target.Parent then return end
	local absSize = target.AbsoluteSize
	local pos     = target.Position
	local anchor  = target.AnchorPoint
	local pxX = pos.X.Scale * screenSize.X + pos.X.Offset - anchor.X * absSize.X
	local pxY = pos.Y.Scale * screenSize.Y + pos.Y.Offset - anchor.Y * absSize.Y
	local maxX = math.max(0, screenSize.X - absSize.X)
	local maxY = math.max(0, screenSize.Y - absSize.Y)
	target.Position = UDim2.new(
		0, math.clamp(pxX, 0, maxX) + anchor.X * absSize.X,
		0, math.clamp(pxY, 0, maxY) + anchor.Y * absSize.Y
	)
end

