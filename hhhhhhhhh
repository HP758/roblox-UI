	tw(strip, EASE_OUT, {Size = UDim2.new(0, 3, 1, -18)})
	task.delay(0.1, function() tw(msg, EASE_OUT, {TextTransparency = 0}) end)
	tw(progress, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 2)})

	local closed = false
	local function close()
		if closed then return end
		closed = true
		tw(card, EASE_OUT, {Position = UDim2.fromOffset(80, 0), BackgroundTransparency = 1})
		tw(msg, EASE_OUT, {TextTransparency = 1})
		task.wait(0.4)
		if wrap.Parent then wrap:Destroy() end
	end
	card.MouseButton1Click:Connect(close)
	task.delay(duration, close)
end

