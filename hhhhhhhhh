			pick.AnchorPoint = Vector2.new(1, 0.5)
			pick.Position = UDim2.new(1, -12, 0.5, 0)
			pick.Size = UDim2.fromOffset(150, 26)
			pick.BackgroundColor3 = T.SurfaceAlt
			pick.BorderSizePixel = 0
			pick.AutoButtonColor = false
			pick.Font = Enum.Font.GothamMedium
			pick.TextSize = 12
			pick.TextColor3 = T.Text
			pick.Text = ""
			pick.ZIndex = 16
			pick.Active = true
			pick.Parent = r
			corner(pick, UDim.new(0, 6))
			stroke(pick, T.Border, 0.2, 1)

			local pickLabel = Instance.new("TextLabel")
			pickLabel.BackgroundTransparency = 1
			pickLabel.Position = UDim2.new(0, 10, 0, 0)
			pickLabel.Size = UDim2.new(1, -28, 1, 0)
			pickLabel.Font = Enum.Font.Gotham
			pickLabel.TextSize = 12
			pickLabel.TextXAlignment = Enum.TextXAlignment.Left
			pickLabel.TextColor3 = T.Text
			pickLabel.Text = current
			pickLabel.ZIndex = 17
			pickLabel.Parent = pick

			local arrow = Instance.new("TextLabel")
			arrow.BackgroundTransparency = 1
			arrow.AnchorPoint = Vector2.new(1, 0.5)
			arrow.Position = UDim2.new(1, -8, 0.5, 0)
			arrow.Size = UDim2.fromOffset(14, 14)
			arrow.Font = Enum.Font.GothamSemibold
			arrow.TextSize = 11
			arrow.TextColor3 = T.TextMuted
			arrow.Text = "▾"
			arrow.ZIndex = 17
			arrow.Parent = pick

			local panel = Instance.new("Frame")
			panel.BackgroundColor3 = T.Surface
			panel.BorderSizePixel = 0
			panel.Visible = false
			panel.ZIndex = 220
			panel.Active = true
			panel.ClipsDescendants = true
			panel.Parent = overlayLayer
			corner(panel, UDim.new(0, 8))
			stroke(panel, T.Border, 0.1, 1)

			local listScroll = Instance.new("ScrollingFrame")
			listScroll.Size = UDim2.fromScale(1,1)
			listScroll.BackgroundTransparency = 1
			listScroll.BorderSizePixel = 0
			listScroll.ScrollBarThickness = 2
			listScroll.ScrollBarImageColor3 = T.TextMuted
			listScroll.CanvasSize = UDim2.new(0,0,0,0)
			listScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
			listScroll.ScrollingDirection = Enum.ScrollingDirection.Y
			listScroll.ElasticBehavior = Enum.ElasticBehavior.Never
			listScroll.ZIndex = 221
			listScroll.Active = true
			listScroll.Parent = panel

			local ll = Instance.new("UIListLayout")
			ll.Parent = listScroll
			ll.Padding = UDim.new(0, 2)
			ll.SortOrder = Enum.SortOrder.LayoutOrder

			local lp = Instance.new("UIPadding")
			lp.PaddingTop = UDim.new(0, 4)
			lp.PaddingBottom = UDim.new(0, 4)
			lp.PaddingLeft = UDim.new(0, 4)
			lp.PaddingRight = UDim.new(0, 4)
			lp.Parent = listScroll

			local optBtns = {}
			local opened = false
			local closeDropdown
			local openDropdown

			closeDropdown = function()
				if not opened then return end
				opened = false
				tw(arrow, EASE_FAST, {Rotation = 0})
				if panel and panel.Parent then
					tw(panel, EASE_FAST, {
						BackgroundTransparency = 1,
						Size = UDim2.fromOffset(panel.AbsoluteSize.X, 0)
					})
				end
				task.delay(0.16, function()
					if not opened and panel and panel.Parent then panel.Visible = false end
				end)
			end

			openDropdown = function()
				if opened then return end
				opened = true

				local pickAbs = pick.AbsolutePosition
				local pickSize = pick.AbsoluteSize
				local screenSize = gui.AbsoluteSize
				local h = math.min(#options * 28 + 8, 160)

				local spaceBelow = screenSize.Y - (pickAbs.Y + pickSize.Y)
				local spaceAbove = pickAbs.Y
				local openUp = spaceBelow < h + 10 and spaceAbove > spaceBelow

				local px = pickAbs.X
				local py = openUp and (pickAbs.Y - h - 4) or (pickAbs.Y + pickSize.Y + 4)

				px = math.clamp(px, 4, screenSize.X - pickSize.X - 4)

				panel.Position = UDim2.fromOffset(px, py)
				panel.Size = UDim2.fromOffset(pickSize.X, 0)
				panel.BackgroundTransparency = 1
				panel.Visible = true

				tw(panel, EASE_OUT, {
					BackgroundTransparency = 0,
					Size = UDim2.fromOffset(pickSize.X, h)
				})
				arrow.Text = openUp and "▴" or "▾"

				for i, ob in ipairs(optBtns) do
					local lbl = ob.btn:FindFirstChild("OptLabel")
					if lbl then lbl.TextTransparency = 1 end
					task.delay((i-1) * 0.03, function()
						if ob.btn.Parent and lbl then
							tw(lbl, EASE_FAST, {TextTransparency = 0})
						end
					end)
				end
			end

			for _, opt in ipairs(options) do
				local b = Instance.new("TextButton")
				b.Size = UDim2.new(1, 0, 0, 26)
				b.BackgroundColor3 = T.SurfaceAlt
				b.BackgroundTransparency = 1
				b.BorderSizePixel = 0
				b.AutoButtonColor = false
				b.Font = Enum.Font.Gotham
				b.TextSize = 12
				b.TextColor3 = T.Text
				b.Text = ""
				b.ZIndex = 222
				b.Active = true
				b.Parent = listScroll
				corner(b, UDim.new(0, 6))

				local optLabel = Instance.new("TextLabel")
				optLabel.Name = "OptLabel"
				optLabel.BackgroundTransparency = 1
				optLabel.Position = UDim2.new(0, 10, 0, 0)
				optLabel.Size = UDim2.new(1, -30, 1, 0)
				optLabel.Font = Enum.Font.Gotham
				optLabel.TextSize = 12
				optLabel.TextXAlignment = Enum.TextXAlignment.Left
				optLabel.TextColor3 = T.Text
				optLabel.Text = opt
				optLabel.ZIndex = 223
				optLabel.Parent = b

				local check = Instance.new("TextLabel")
				check.BackgroundTransparency = 1
				check.AnchorPoint = Vector2.new(1, 0.5)
				check.Position = UDim2.new(1, -8, 0.5, 0)
				check.Size = UDim2.fromOffset(14, 14)
				check.Font = Enum.Font.GothamSemibold
				check.TextSize = 12
				check.TextColor3 = T.Accent
				check.Text = (opt == current) and "✓" or ""
				check.ZIndex = 223
				check.Parent = b

				b.MouseEnter:Connect(function() tw(b, EASE_FAST, {BackgroundTransparency = 0}) end)
				b.MouseLeave:Connect(function() tw(b, EASE_FAST, {BackgroundTransparency = 1}) end)

				b.MouseButton1Click:Connect(function()
					current = opt
					pickLabel.Text = opt
					for _, ob in ipairs(optBtns) do
						ob.check.Text = (ob.opt == opt) and "✓" or ""
					end
					closeDropdown()
					if cb then task.spawn(cb, opt) end
				end)

				table.insert(optBtns, {opt = opt, btn = b, check = check})
			end

			pick.MouseButton1Click:Connect(function()
				if opened then closeDropdown() else openDropdown() end
			end)

			table.insert(globalClickListeners, function(i)
				if not opened then return end
				if not panel.Parent then return end
				local ax, ay = i.Position.X, i.Position.Y
				local p1 = panel.AbsolutePosition
				local p2 = p1 + panel.AbsoluteSize
				local k1 = pick.AbsolutePosition
				local k2 = k1 + pick.AbsoluteSize
				local inPanel = ax >= p1.X and ax <= p2.X and ay >= p1.Y and ay <= p2.Y
				local inPick  = ax >= k1.X and ax <= k2.X and ay >= k1.Y and ay <= k2.Y
				if not inPanel and not inPick then
					closeDropdown()
				end
			end)

			table.insert(Window._dropdowns, closeDropdown)

			local api = {}
			function api:Set(v)
				current = v
				pickLabel.Text = v
				for _, ob in ipairs(optBtns) do
					ob.check.Text = (ob.opt == v) and "✓" or ""
				end
			end
			function api:Get() return current end
			return api
		end

		function Tab:AddInput(text, placeholder, cb)
			local r = rowBase(40)

			local l = Instance.new("TextLabel")
			l.BackgroundTransparency = 1
			l.Position = UDim2.new(0, 12, 0, 0)
			l.Size = UDim2.new(0.4, 0, 1, 0)
			l.Font = Enum.Font.Gotham
			l.TextSize = 12
			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextColor3 = T.Text
			l.Text = text
			l.ZIndex = 16
			l.Parent = r

			local box = Instance.new("TextBox")
			box.AnchorPoint = Vector2.new(1, 0.5)
			box.Position = UDim2.new(1, -12, 0.5, 0)
			box.Size = UDim2.fromOffset(160, 26)
			box.BackgroundColor3 = T.SurfaceAlt
			box.BorderSizePixel = 0
			box.Font = Enum.Font.Gotham
			box.TextSize = 12
			box.TextColor3 = T.Text
			box.PlaceholderText = placeholder or ""
			box.PlaceholderColor3 = T.TextMuted
			box.Text = ""
			box.ClearTextOnFocus = false
			box.ZIndex = 16
			box.Parent = r
			corner(box, UDim.new(0, 6))
			stroke(box, T.Border, 0.2, 1)

			local pad = Instance.new("UIPadding")
			pad.PaddingLeft = UDim.new(0, 8)
			pad.PaddingRight = UDim.new(0, 8)
			pad.Parent = box

			box.Focused:Connect(function()
				tw(box, EASE_FAST, {BackgroundColor3 = T.AccentSoft})
			end)
			box.FocusLost:Connect(function()
				tw(box, EASE_FAST, {BackgroundColor3 = T.SurfaceAlt})
				if cb then task.spawn(cb, box.Text) end
			end)

			local api = {}
			function api:Set(t) box.Text = t end
			function api:Get() return box.Text end
			return api
		end

		function Tab:AddKeybind(text, defaultKey, cb)
			local r = rowBase(40)
			local key = defaultKey
			local listening = false

			local l = Instance.new("TextLabel")
			l.BackgroundTransparency = 1
			l.Position = UDim2.new(0, 12, 0, 0)
			l.Size = UDim2.new(1, -100, 1, 0)
			l.Font = Enum.Font.Gotham
			l.TextSize = 12
			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextColor3 = T.Text
			l.Text = text
			l.ZIndex = 16
			l.Parent = r

			local btn = Instance.new("TextButton")
			btn.AnchorPoint = Vector2.new(1, 0.5)
			btn.Position = UDim2.new(1, -12, 0.5, 0)
			btn.Size = UDim2.fromOffset(76, 26)
			btn.BackgroundColor3 = T.SurfaceAlt
			btn.BorderSizePixel = 0
			btn.AutoButtonColor = false
			btn.Font = Enum.Font.GothamSemibold
			btn.TextSize = 11
			btn.TextColor3 = T.Text
			btn.Text = key and key.Name or "未绑定"
			btn.ZIndex = 16
			btn.Active = true
			btn.Parent = r
			corner(btn, UDim.new(0, 6))
			stroke(btn, T.Border, 0.2, 1)

			btn.MouseButton1Click:Connect(function()
				listening = true
				btn.Text = "按下按键..."
				tw(btn, EASE_FAST, {BackgroundColor3 = T.AccentSoft})
			end)

			UserInputService.InputBegan:Connect(function(input, gp)
				if listening and input.UserInputType == Enum.UserInputType.Keyboard then
					listening = false
					key = input.KeyCode
					btn.Text = key.Name
					tw(btn, EASE_FAST, {BackgroundColor3 = T.SurfaceAlt})
				elseif key and not gp and not listening
					and input.UserInputType == Enum.UserInputType.Keyboard
					and input.KeyCode == key then
					if cb then task.spawn(cb) end
				end
			end)

			local api = {}
			function api:Set(k) key = k; btn.Text = k.Name end
			function api:Get() return key end
			return api
		end

		function Tab:AddColorPicker(text, defaultColor, cb)
			local color = defaultColor or Color3.fromRGB(255,255,255)
			local r = rowBase(40)

			local l = Instance.new("TextLabel")
			l.BackgroundTransparency = 1
			l.Position = UDim2.new(0, 12, 0, 0)
			l.Size = UDim2.new(1, -60, 1, 0)
			l.Font = Enum.Font.Gotham
			l.TextSize = 12
			l.TextXAlignment = Enum.TextXAlignment.Left
			l.TextColor3 = T.Text
			l.Text = text
			l.ZIndex = 16
			l.Parent = r

			local swatch = Instance.new("TextButton")
			swatch.AnchorPoint = Vector2.new(1, 0.5)
			swatch.Position = UDim2.new(1, -12, 0.5, 0)
			swatch.Size = UDim2.fromOffset(36, 22)
			swatch.BackgroundColor3 = color
			swatch.BorderSizePixel = 0
			swatch.AutoButtonColor = false
			swatch.Text = ""
			swatch.ZIndex = 16
			swatch.Active = true
			swatch.Parent = r
			corner(swatch, UDim.new(0, 6))
			stroke(swatch, T.Border, 0.2, 1)

			-- 简易颜色选择浮层
			local pickerOpen = false
			local picker = Instance.new("Frame")
			picker.Size = UDim2.fromOffset(180, 80)
			picker.BackgroundColor3 = T.Surface
			picker.BorderSizePixel = 0
			picker.Visible = false
			picker.ZIndex = 230
			picker.Active = true
			picker.Parent = overlayLayer
			corner(picker, UDim.new(0, 8))
			stroke(picker, T.Border, 0.1, 1)

			local presets = {
				Color3.fromRGB(255,80,80), Color3.fromRGB(255,160,80), Color3.fromRGB(255,220,80),
				Color3.fromRGB(80,200,120), Color3.fromRGB(80,180,255), Color3.fromRGB(160,80,255),
				Color3.fromRGB(255,80,180), Color3.fromRGB(40,40,50),  Color3.fromRGB(255,255,255),
			}
			local grid = Instance.new("UIGridLayout")
			grid.CellSize = UDim2.fromOffset(36, 28)
			grid.CellPadding = UDim2.fromOffset(6, 6)
			grid.Parent = picker
			local pp = Instance.new("UIPadding")
			pp.PaddingTop = UDim.new(0, 12)
			pp.PaddingLeft = UDim.new(0, 12)
			pp.Parent = picker

			for _, c in ipairs(presets) do
				local cb2 = Instance.new("TextButton")
				cb2.BackgroundColor3 = c
				cb2.BorderSizePixel = 0
				cb2.AutoButtonColor = false
				cb2.Text = ""
				cb2.ZIndex = 231
				cb2.Parent = picker
				corner(cb2, UDim.new(0, 5))
				stroke(cb2, T.Border, 0.4, 1)
				cb2.MouseButton1Click:Connect(function()
					color = c
					swatch.BackgroundColor3 = c
					if cb then task.spawn(cb, c) end
					pickerOpen = false
					picker.Visible = false
				end)
			end

			swatch.MouseButton1Click:Connect(function()
				pickerOpen = not pickerOpen
				if pickerOpen then
					local sa = swatch.AbsolutePosition
					picker.Position = UDim2.fromOffset(sa.X - 144, sa.Y + swatch.AbsoluteSize.Y + 4)
					picker.Visible = true
				else
					picker.Visible = false
				end
			end)

			table.insert(globalClickListeners, function(i)
				if not pickerOpen then return end
				local ax, ay = i.Position.X, i.Position.Y
				local p1 = picker.AbsolutePosition
				local p2 = p1 + picker.AbsoluteSize
				local k1 = swatch.AbsolutePosition
				local k2 = k1 + swatch.AbsoluteSize
				local inP = ax >= p1.X and ax <= p2.X and ay >= p1.Y and ay <= p2.Y
				local inK = ax >= k1.X and ax <= k2.X and ay >= k1.Y and ay <= k2.Y
				if not inP and not inK then
					pickerOpen = false
					picker.Visible = false
				end
			end)

			local api = {}
			function api:Set(c) color = c; swatch.BackgroundColor3 = c end
			function api:Get() return color end
			return api
		end

		if not Window.current then
			task.delay(0.05, function()
				switchTab(name)
				task.wait(0.1)
				moveIndicator(btn)
			end)
		end
		return Tab
	end

	------------------------------------------------------------------
	-- 公开方法
	------------------------------------------------------------------
	function Window:SelectTab(name)
		if Window.tabs[name] then switchTab(name) end
	end

	function Window:SetTitle(text)
		winTitle.Text = text
		iTitle.Text = text
	end

	function Window:Show()
		window.Visible = true
		glow.Visible = true
		tw(windowScale, EASE_SPRING, {Scale = 1})
		tw(window, EASE_OUT, {BackgroundTransparency = 0})
		tw(glow, EASE_OUT, {ImageTransparency = 0.85})
	end

	function Window:Hide()
		tw(windowScale, EASE_FAST, {Scale = 0.9})
		tw(window, EASE_OUT, {BackgroundTransparency = 1})
		tw(glow, EASE_OUT, {ImageTransparency = 1})
		task.delay(0.3, function()
			if window.Parent then window.Visible = false end
			glow.Visible = false
		end)
	end

	function Window:SetWindowVisible(state)
		if state then self:Show() else self:Hide() end
	end

	function Window:Toggle()
		if window.Visible then self:Hide() else self:Show() end
	end

	function Window:Bind(keycode)
		UserInputService.InputBegan:Connect(function(input, gp)
			if not gp and input.KeyCode == keycode then
				self:Toggle()
			end
		end)
	end

	function Window:Destroy()
		if window.Parent then window:Destroy() end
		if island.Parent then island:Destroy() end
		if overlayLayer.Parent then overlayLayer:Destroy() end
		if glow.Parent then glow:Destroy() end
	end

	------------------------------------------------------------------
	-- 最小化
	------------------------------------------------------------------
	local minimized = false
	setMin = function(s)
		minimized = s
		if s then
			tw(windowScale, EASE_FAST, {Scale = 0.85})
			tw(window, EASE_OUT, {BackgroundTransparency = 1})
			tw(glow, EASE_OUT, {ImageTransparency = 1})
			if bgImage then tw(bgImage, EASE_OUT, {ImageTransparency = 1}) end
			task.delay(0.3, function()
				if minimized and window.Parent then
					window.Visible = false
					glow.Visible = false
				end
			end)

			island.Visible = true
			island.Size = UDim2.fromOffset(40, 40)
			island.BackgroundTransparency = 1
			tw(island, EASE_SPRING, {Size = cfg.IslandSize, BackgroundTransparency = 0.02})
		else
			window.Visible = true
			glow.Visible = true
			windowScale.Scale = 0.85
			window.BackgroundTransparency = 1
			tw(windowScale, EASE_SPRING, {Scale = 1})
			tw(window, EASE_OUT, {BackgroundTransparency = 0})
			tw(glow, EASE_OUT, {ImageTransparency = 0.85})
			if bgImage then tw(bgImage, EASE_OUT, {ImageTransparency = T.BgDim}) end

			tw(island, EASE_OUT, {Size = UDim2.fromOffset(40, 40), BackgroundTransparency = 1})
			task.delay(0.3, function() if not minimized and island.Parent then island.Visible = false end end)
		end
	end

	btnMin.MouseButton1Click:Connect(function() setMin(true) end)

	btnClose.MouseButton1Click:Connect(function()
		tw(windowScale, EASE_FAST, {Scale = 0.7})
		tw(window, EASE_OUT, {BackgroundTransparency = 1})
		tw(glow, EASE_OUT, {ImageTransparency = 1})
		tw(island, EASE_OUT, {Size = UDim2.fromOffset(0,0), BackgroundTransparency = 1})
		task.wait(0.36)
		Window:Destroy()
	end)

	-- glow 跟随窗口
	RunService.RenderStepped:Connect(function()
		if glow.Parent and window.Parent and window.Visible then
			glow.Position = window.Position
		end
	end)

	------------------------------------------------------------------
	-- 加载 → 弹出
	------------------------------------------------------------------
	showLoader(gui, function()
		window.Position = UDim2.new(0.5, 0, 0.5, 0)
		window.BackgroundTransparency = 1
		windowScale.Scale = 0.85
		window.Visible = true
		glow.Visible = true
		glow.ImageTransparency = 1
		tw(windowScale, EASE_SPRING, {Scale = 1})
		tw(window, EASE_OUT, {BackgroundTransparency = 0})
		tw(glow, EASE_SLOW, {ImageTransparency = 0.85})
		if bgImage then tw(bgImage, EASE_OUT, {ImageTransparency = T.BgDim}) end
		task.wait()
		clampPosition(window, gui.AbsoluteSize)
	end)

	gui:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
		if window.Visible then clampPosition(window, gui.AbsoluteSize) end
		if island.Visible then clampPosition(island, gui.AbsoluteSize) end
	end)

	return Window
end

return DynamicUI
