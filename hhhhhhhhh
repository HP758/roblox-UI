	kind = kind or "info"
	local gui = ensureGui()
	local holder = ensureNotifyHolder(gui)

	-- 用偏冷的、设计感强的色，而不是标准 RGB
	local colors = {
		success = Color3.fromRGB(72, 181, 130),
		warn    = Color3.fromRGB(218, 165, 70),
		error   = Color3.fromRGB(220, 96, 96),
		info    = Color3.fromRGB(86, 122, 200),
	}
	local accent = colors[kind] or colors.info

	local card = Instance.new("Frame")
	card.Size = UDim2.fromOffset(252, 46)
	card.BackgroundColor3 = Color3.fromRGB(252, 252, 253)
	card.BackgroundTransparency = 1
	card.BorderSizePixel = 0
	card.ZIndex = 1001
	card.Parent = holder
	corner(card, UDim.new(0, 10))
	stroke(card, Color3.fromRGB(218, 220, 230), 0.1, 1)

	local strip = Instance.new("Frame")
	strip.Size = UDim2.new(0, 3, 1, -16)
	strip.Position = UDim2.new(0, 10, 0, 8)
	strip.BackgroundColor3 = accent
	strip.BorderSizePixel = 0
	strip.ZIndex = 1002
	strip.Parent = card
	corner(strip, UDim.new(1,0))

	local msg = Instance.new("TextLabel")
	msg.BackgroundTransparency = 1
	msg.Position = UDim2.new(0, 22, 0, 0)
	msg.Size = UDim2.new(1, -32, 1, 0)
	msg.Font = Enum.Font.Gotham
	msg.TextSize = 12
	msg.TextXAlignment = Enum.TextXAlignment.Left
	msg.TextColor3 = Color3.fromRGB(38, 40, 50)
	msg.TextTransparency = 1
	msg.Text = text
	msg.TextWrapped = true
	msg.ZIndex = 1003
	msg.Parent = card

	tw(card, EASE_OUT, {BackgroundTransparency = 0.02})
	tw(msg,  EASE_OUT, {TextTransparency = 0})

	task.delay(2.2, function()
		if not card.Parent then return end
		tw(card, EASE_OUT, {BackgroundTransparency = 1})
		tw(msg,  EASE_OUT, {TextTransparency = 1})
		task.wait(0.4)
		card:Destroy()
	end)
end

