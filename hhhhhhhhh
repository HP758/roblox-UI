	local function switchTab(name)
		if Window.current == name then return end
		for _, fn in ipairs(Window._dropdowns) do pcall(fn) end
		for n, t in pairs(Window.tabs) do
			local active = (n == name)
			tw(t.button, EASE_FAST, {BackgroundColor3 = active and T.AccentSoft or T.BgDeep})
			tw(t.label, EASE_FAST, {TextColor3 = active and T.Text or T.TextSub})
			tw(t.iconLbl, EASE_FAST, {TextColor3 = active and T.Accent or T.TextSub})
			tw(t.indicator, EASE_FAST, {
				BackgroundTransparency = active and 0 or 1,
				Size = active and UDim2.new(0, 3, 0.55, 0) or UDim2.new(0, 3, 0, 0),
			})
			if active then
				t.page.Visible = true
				currentTabLabel.Text = name
			else
				t.page.Visible = false
			end
		end
		Window.current = name
	end

