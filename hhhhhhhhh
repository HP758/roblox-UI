			local thumb = Instance.new("Frame")
			thumb.AnchorPoint = Vector2.new(0.5, 0.5)
			thumb.Position = UDim2.new((default-min)/math.max(max-min,1), 0, 0.5, 0)
			thumb.Size = UDim2.fromOffset(14, 14)
			thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
			thumb.BorderSizePixel = 0
			thumb.ZIndex = 18
			thumb.Parent = track
			corner(thumb, UDim.new(1,0))
			stroke(thumb, T.Accent, 0, 1.5)

			-- 目标圈
			local targetRing = Instance.new("Frame")
			targetRing.AnchorPoint = Vector2.new(0.5, 0.5)
			targetRing.Position = UDim2.fromScale(0.5, 0.5)
			targetRing.Size = UDim2.fromOffset(14, 14)
			targetRing.BackgroundTransparency = 1
			targetRing.BorderSizePixel = 0
			targetRing.ZIndex = 19
			targetRing.Parent = thumb
			corner(targetRing, UDim.new(1,0))
			stroke(targetRing, T.Accent, 1, 2)

			local hit = Instance.new("TextButton")
			hit.BackgroundTransparency = 1
			hit.Text = ""
			hit.Size = UDim2.new(1, 20, 0, 28)
			hit.Position = UDim2.new(0, -10, 0.5, -14)
			hit.ZIndex = 19
			hit.AutoButtonColor = false
			hit.Active = true
			hit.Parent = track

			hit.MouseEnter:Connect(function() tw(thumb, EASE_FAST, {Size = UDim2.fromOffset(16, 16)}) end)
			hit.MouseLeave:Connect(function()
				if not (UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)) then
					tw(thumb, EASE_FAST, {Size = UDim2.fromOffset(14, 14)})
				end
			end)

			local dragging = false
			local lastValue = default

			local function setFromX(x)
				local rel = math.clamp((x - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
				local v = math.floor(min + (max - min) * rel + 0.5)
				fill.Size = UDim2.new(rel, 0, 1, 0)
				thumb.Position = UDim2.new(rel, 0, 0.5, 0)
				val.Text = tostring(v)
				if v ~= lastValue then
					lastValue = v
					if cb then task.spawn(cb, v) end
				end
			end

			hit.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					tw(thumb, EASE_FAST, {Size = UDim2.fromOffset(18, 18)})
					tw(targetRing, EASE_FAST, {Size = UDim2.fromOffset(28,28), BackgroundTransparency = 1})
					if targetRing:FindFirstChildOfClass("UIStroke") then
						tw(targetRing:FindFirstChildOfClass("UIStroke"), EASE_FAST, {Transparency = 0.3})
					end
					setFromX(i.Position.X)
				end
			end)

			local conn1 = UserInputService.InputChanged:Connect(function(i)
				if not dragging then return end
				if i.UserInputType == Enum.UserInputType.MouseMovement
				or i.UserInputType == Enum.UserInputType.Touch then
					setFromX(i.Position.X)
				end
			end)

			local conn2 = RunService.RenderStepped:Connect(function()
				if dragging then
					setFromX(UserInputService:GetMouseLocation().X)
				end
			end)

			local conn3 = UserInputService.InputEnded:Connect(function(i)
				if dragging and (i.UserInputType == Enum.UserInputType.MouseButton1
				or i.UserInputType == Enum.UserInputType.Touch) then
					dragging = false
					tw(thumb, EASE_SPRING, {Size = UDim2.fromOffset(14, 14)})
					tw(targetRing, EASE_FAST, {Size = UDim2.fromOffset(14,14)})
					if targetRing:FindFirstChildOfClass("UIStroke") then
						tw(targetRing:FindFirstChildOfClass("UIStroke"), EASE_FAST, {Transparency = 1})
					end
				end
			end)

			r.AncestryChanged:Connect(function(_, parent)
				if not parent then
					if conn1 then conn1:Disconnect() end
					if conn2 then conn2:Disconnect() end
					if conn3 then conn3:Disconnect() end
				end
			end)

			if tip then attachTooltip(r, tip) end
			local api = {Instance = r}
			function api:Set(v)
				v = math.clamp(v, min, max)
				lastValue = v
				local rel = (v-min)/math.max(max-min,1)
				fill.Size = UDim2.new(rel, 0, 1, 0)
				thumb.Position = UDim2.new(rel, 0, 0.5, 0)
				val.Text = tostring(v)
			end
			function api:Get() return lastValue end
			return api
		end

