			l.Text = text
			l.ZIndex = 16
			l.Parent = r

			local track = Instance.new("TextButton")
			track.AnchorPoint = Vector2.new(1, 0.5)
			track.Position = UDim2.new(1, -12, 0.5, 0)
			track.Size = UDim2.fromOffset(36, 20)
			track.AutoButtonColor = false
			track.Text = ""
			track.BackgroundColor3 = state and T.Accent or T.Track
			track.BorderSizePixel = 0
			track.ZIndex = 16
			track.Active = true
			track.Parent = r
			corner(track, UDim.new(1,0))

			local glowEffect = Instance.new("UIStroke")
			glowEffect.Color = T.Accent
			glowEffect.Transparency = state and 0.5 or 1
			glowEffect.Thickness = 3
			glowEffect.Parent = track

			local dot = Instance.new("Frame")
			dot.Size = UDim2.fromOffset(16, 16)
			dot.Position = state and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
			dot.BackgroundColor3 = Color3.fromRGB(255,255,255)
			dot.BorderSizePixel = 0
			dot.ZIndex = 17
			dot.Parent = track
			corner(dot, UDim.new(1,0))

			local dotScale = Instance.new("UIScale")
			dotScale.Parent = dot

			task.spawn(function()
				while track.Parent do
					if state then
						tw(glowEffect, TweenInfo.new(1.2, Enum.EasingStyle.Sine), {Transparency = 0.8})
						task.wait(1.2)
						tw(glowEffect, TweenInfo.new(1.2, Enum.EasingStyle.Sine), {Transparency = 0.5})
						task.wait(1.2)
					else
						task.wait(0.3)
					end
				end
			end)

			track.MouseButton1Click:Connect(function()
				state = not state
				tw(dotScale, EASE_FAST, {Scale = 0.7})
				task.delay(0.1, function() tw(dotScale, EASE_SPRING, {Scale = 1}) end)
				tw(track, EASE_FAST, {BackgroundColor3 = state and T.Accent or T.Track})
				tw(glowEffect, EASE_FAST, {Transparency = state and 0.5 or 1})
				tw(dot, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
					Position = state and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
				})
				if state then
					spawnParticles(track, 18, 10, T.Accent, 6)
				end
				if cb then task.spawn(cb, state) end
				DynamicUI:Notify((state and "已开启 · " or "已关闭 · ") .. text, state and "success" or "warn")
			end)

			if tip then attachTooltip(r, tip) end
			local api = {Instance = r}
			function api:Set(s)
				state = s and true or false
				tw(track, EASE_FAST, {BackgroundColor3 = state and T.Accent or T.Track})
				tw(dot, EASE_FAST, {Position = state and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)})
			end
			function api:Get() return state end
			return api
		end

