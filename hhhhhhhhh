------------------------------------------------------------------
-- 全窗口拖动（修复"只有顶上能拖"）
-- · target 自身监听 InputBegan
-- · 控件因为 Active=true，会消费输入，不会触发拖动
------------------------------------------------------------------
local function makeDraggable(target, gui, opts)
	opts = opts or {}
	local dragging = false
	local activeInput = nil  -- 只追踪一个输入，避免触屏重复触发
	local startInputPos
	local startTargetPos

	target.Active = true

	target.InputBegan:Connect(function(i)
		if dragging then return end
		if i.UserInputType ~= Enum.UserInputType.MouseButton1
		and i.UserInputType ~= Enum.UserInputType.Touch then return end

		-- 如果点中的是会消费输入的子控件（按钮、滑条、toggle），就不拖
		-- 用 GuiService 的 GuiObjectsAtPosition 判断更准
		local objs = PlayerGui:GetGuiObjectsAtPosition(i.Position.X, i.Position.Y)
		for _, o in ipairs(objs) do
			-- 找到的第一个 Active=true 且不是 target 自己/dragHandle 的，就放弃
			if o ~= target and (o:IsA("TextButton") or o:IsA("ImageButton") or o:IsA("TextBox")) then
				return
			end
			if o == target then break end
		end

		dragging = true
		activeInput = i
		startInputPos = i.Position
		startTargetPos = target.Position
	end)

	UserInputService.InputChanged:Connect(function(i)
		if not dragging then return end
		if i ~= activeInput
		and i.UserInputType ~= Enum.UserInputType.MouseMovement
		and i.UserInputType ~= Enum.UserInputType.Touch then return end

		local d = i.Position - startInputPos
		target.Position = UDim2.new(
			startTargetPos.X.Scale, startTargetPos.X.Offset + d.X,
			startTargetPos.Y.Scale, startTargetPos.Y.Offset + d.Y
		)
		clampPosition(target, gui.AbsoluteSize)
	end)

	UserInputService.InputEnded:Connect(function(i)
		if dragging and (i == activeInput
		or i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch) then
			dragging = false
			activeInput = nil
			clampPosition(target, gui.AbsoluteSize)
		end
	end)
end

------------------------------------------------------------------
-- 全局点击（用于 dropdown 自动收起）
------------------------------------------------------------------
local globalClickListeners = {}
UserInputService.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1
	or i.UserInputType == Enum.UserInputType.Touch then
		for _, fn in ipairs(globalClickListeners) do
			pcall(fn, i)
		end
	end
end)

